TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Browser (optional, default headless). Only HEADLESS=false opens a visible window.
HEADLESS=true

# Alert deduplication (optional)
ALERT_COOLDOWN_HOURS=12
ALERT_PRICE_IMPROVEMENT_PERCENT=5

# Rolling baseline window (optional, default 50). Number of most-recent prices
# averaged into each watch/product market baseline.
BASELINE_WINDOW_SIZE=50

# Anomaly engine thresholds (optional)
ANOMALY_MIN_PRODUCT_SAMPLES=10
ANOMALY_MIN_WATCH_SAMPLES=10
ANOMALY_SEVERE_RATIO=0.30
ANOMALY_CRITICAL_RATIO=0.15
ANOMALY_ABSURD_RATIO=0.10

# Watch mode poll interval (optional, default 15)
POLL_INTERVAL_MINUTES=15

# Health alerts (optional, separate from deal alert deduplication)
HEALTH_ALERTS_ENABLED=true
HEALTH_DAILY_DIGEST_HOUR=20
HEALTH_WARNING_CONSECUTIVE=3
HEALTH_WARNING_COOLDOWN_HOURS=24
HEALTH_CRITICAL_COOLDOWN_MINUTES=60

# Micro Center smoke test / future adapter (optional, default 181 = Denver)
MICROCENTER_STORE_ID=181
